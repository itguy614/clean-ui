{
  "name": "@itguy614/clean-ui",
  "version": "0.3.0",
  "type": "module",
  "description": "A clean, dark-mode-ready Vue UI component library",
  "license": "MIT",
  "author": "itguy614",
  "main": "./dist/clean-ui.umd.cjs",
  "module": "./dist/clean-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/clean-ui.js",
      "require": "./dist/clean-ui.umd.cjs"
    },
    "./styles": "./dist/clean-ui.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@phosphor-icons/vue": "^2.2.1"
  }
}
