{
  "name": "@itguy614/clean-ui",
  "version": "1.0.1",
  "type": "module",
  "description": "A clean, dark-mode-ready Vue 3 component library — 100+ token-driven, themeable, accessible components.",
  "license": "MIT",
  "author": "Kurt Wolf",
  "homepage": "https://itguy614.github.io/clean-ui/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itguy614/clean-ui.git",
    "directory": "packages/clean-ui"
  },
  "bugs": {
    "url": "https://github.com/itguy614/clean-ui/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "components",
    "ui",
    "design-system",
    "tailwindcss",
    "dark-mode",
    "typescript",
    "accessible"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./dist/clean-ui.css",
    "./*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly && node scripts/postbuild.mjs",
    "size": "node scripts/postbuild.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@phosphor-icons/vue": "^2.2.1"
  }
}
